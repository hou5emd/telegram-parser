{
  "name": "vacancy_parser",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run build:webapp",
    "build:webapp": "bun run scripts/build-webapp.ts",
    "dev": "bun run dev:webapp & bun run dev:server",
    "dev:server": "bun --watch index.ts",
    "dev:webapp": "bun build ./src/webapp/index.html --outdir ./dist/webapp --public-path /app/ --watch",
    "start": "bun run build:webapp && bun run index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.8",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
